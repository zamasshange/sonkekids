{
  "rewrites": [
    {
      "source": "/_next/static/:path*",
      "destination": "https://pbskids.org/_next/static/:path*"
    },
    {
      "source": "/_next/static/chunks/:path*",
      "destination": "https://pbskids.org/_next/static/chunks/:path*"
    },
    {
      "source": "/_next/image",
      "destination": "https://pbskids.org/_next/image"
    },
    {
      "source": "/puma/:path*",
      "destination": "https://pbskids.org/puma/:path*"
    },
    {
      "source": "/sw.js",
      "destination": "https://pbskids.org/sw.js"
    }
  ]
}
